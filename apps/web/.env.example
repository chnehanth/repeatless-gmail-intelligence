# Frontend env (Vite). Copy to apps/web/.env.local for local overrides.

# In dev, leave empty — Vite proxies /api to the backend (see vite.config.ts).
# In production, set this to your deployed API origin (no trailing slash), e.g.
# VITE_API_BASE_URL=https://api.your-domain.com
VITE_API_BASE_URL=

# Backend target for the dev proxy (defaults to http://localhost:4000).
VITE_API_PROXY=http://localhost:4000
